PROJECT_NAME           = per4m
PROJECT_BRIEF          = Probabilistic stopping utilities based on kernel density estimation.
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO

OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

INPUT                  = README.md \
                         include/per4m
FILE_PATTERNS          = *.h \
                         *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

EXCLUDE                = include/per4m/detail \
                         include/per4m/ProbabilisticFilter.h \
                         include/per4m/Ribeiro.h
EXCLUDE_PATTERNS       = */detail/* \
                         */ProbabilisticFilter.h \
                         */Ribeiro.h

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

